GITHUB_TOKEN=
BOOTSTRAP_API_KEY=dev-bootstrap-key-change-me
PORT=3100

# Destino de repos (owner = usuario personal u org de GitHub)
GITHUB_ORG_BOOGIEPOP=blanck1945
GITHUB_ORG_REMOTES=blanck1945

# Ruta absoluta a boogiepop-infra/terraform (requiere terraform + AWS creds en PATH)
# Local: carpeta del repo. ECS prod: /mnt/efs/terraform (EFS + clone GitLab al arrancar).
INFRA_TERRAFORM_DIR=C:\Users\elabu\Desktop\side\boogiepop\boogiepop-infra\terraform

# Solo ECS prod (Secrets Manager): token read_repository para clonar boogiepop-infra
# GITLAB_INFRA_TOKEN=
# INFRA_GIT_REPO=https://gitlab.com/boogiepop-phatom/boogiepop-infra.git
# INFRA_GIT_BRANCH=main

# Backend Nest — registrar app en DB (POST/PATCH /api/applications)
# En local, BOOGIEPOP_ADMIN_PASSWORD debe coincidir con SEED_ADMIN_PASSWORD del backend.
# BOOGIEPOP_API_URL=http://localhost:3000
# BOOGIEPOP_ADMIN_EMAIL=admin@boogiepop.dev
# BOOGIEPOP_ADMIN_PASSWORD=<mismo valor que SEED_ADMIN_PASSWORD en boogiepop-backend/.env>

# Org de micro-frontends remotes (opcional):
# GITHUB_ORG_REMOTES=Boogiepop-remotes
